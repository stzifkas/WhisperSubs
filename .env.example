OPENAI_API_KEY=sk-...

# Optional: pre-set a translation target language (or leave blank for UI-only selection)
TARGET_LANGUAGE=

# Models
REALTIME_MODEL=gpt-4o-realtime-preview
WHISPER_MODEL=gpt-4o-transcribe
TRANSLATION_MODEL=gpt-4o-mini
CHAT_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small

# Selective refinement — span confidence thresholds (0.0–1.0)
# Spans below LOW are always repaired; high-risk spans (names, numbers, acronyms)
# below HIGH_RISK are also repaired even at moderate confidence.
REFINEMENT_LOW_CONFIDENCE_THRESHOLD=0.55
REFINEMENT_HIGH_RISK_THRESHOLD=0.80

# Interpreter mode — single preset controlling refinement, correction
# aggressiveness, and the subtitle revision window.
# Options: fast | balanced | broadcast | precision
DEFAULT_INTERPRETER_MODE=balanced

# Optional: default source language for Whisper (leave blank for auto-detect)
WHISPER_LANGUAGE=

# Server VAD defaults (tunable in the UI)
NO_SPEECH_THRESHOLD=0.5            # 0.0–1.0, higher = stricter
VAD_SILENCE_DURATION_MS=500        # ms of silence before a turn ends

# How long (seconds) to keep a disconnected session's transcript/chat available
# for download and follow-up questions before it is purged from memory.
SESSION_TTL_S=3600
